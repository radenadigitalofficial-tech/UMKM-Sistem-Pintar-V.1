{
  "entities": {
    "Business": {
      "title": "Business Profile",
      "description": "UMKM Business details and configuration",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "logo": { "type": "string" },
        "contactInfo": {
          "type": "object",
          "properties": {
            "phone": { "type": "string" },
            "email": { "type": "string" },
            "address": { "type": "string" }
          }
        },
        "ownerId": { "type": "string" }
      }
    },
    "Product": {
      "title": "Product",
      "description": "Product catalog item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction (invoice, receipt, or expense)",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["invoice", "receipt", "expense"] },
        "amount": { "type": "number" },
        "date": { "type": "integer" },
        "status": { "type": "string" },
        "description": { "type": "string" },
        "customerId": { "type": "string" }
      }
    }
  },
  "firestore": {
    "businesses/{businessId}": {
      "schema": "Business",
      "description": "Core business profiles"
    },
    "businesses/{businessId}/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog per business"
    },
    "businesses/{businessId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial records per business"
    }
  }
}
